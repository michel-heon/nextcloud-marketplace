# ============================================================
# image-tests — Variables de configuration des tests VM
# Application locale ADR-600 : séparation config publique / privée
#
# Usage :
#   cp image-tests/env/.env.test.example image-tests/env/.env.test
#   → Ajuster les valeurs dans image-tests/env/.env.test
#
# JAMAIS commiter image-tests/env/.env.test dans Git.
# Ce fichier .example est le seul versionné.
#
# Priorité de chargement (load_env dans lib/common.sh) :
#   1. env/.env          — config projet (AZURE_SUBSCRIPTION_ID, IMAGE_VERSION…)
#   2. env/.env.user     — surcharges personnelles
#   3. image-tests/env/.env.test  ← ce fichier (surcharge test uniquement)
# ============================================================

# ------------------------------------------------------------
# VM de test — Infrastructure Azure
# AZURE_SUBSCRIPTION_ID et AZURE_LOCATION héritées de env/.env
# ------------------------------------------------------------
TEST_RG=rg-nextcloud-test
TEST_VM_NAME=vm-nc-test
TEST_VM_SIZE=Standard_B2s

# ------------------------------------------------------------
# VM de test — Authentification SSH
# ------------------------------------------------------------
TEST_ADMIN_USER=azureuser
TEST_SSH_KEY_PATH=~/.ssh/id_rsa.pub

# ------------------------------------------------------------
# VM de test — Credentials Nextcloud
# Ces valeurs sont éphémères : VM jetable, jamais de production
# ------------------------------------------------------------
TEST_NC_ADMIN_USER=ncadmin
TEST_NC_ADMIN_PASS=changeme123!
TEST_NC_DB_PASS=dbpassword123!
TEST_REDIS_PASS=redis123!
