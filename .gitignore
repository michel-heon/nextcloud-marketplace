# Git ignore rules — nextcloud-marketplace

# ------------------------------------------------------------
# Environment & Secrets
# ------------------------------------------------------------
env/.env
env/.env.user
*.env.local
*.env.prod
*.pem
*.key
*.pfx
*.p12

# ------------------------------------------------------------
# Packer generated files
# ------------------------------------------------------------
packer-manifest.json
crash.log
*.pkrlog
packer/*/build.auto.pkrvars.hcl

# ------------------------------------------------------------
# Terraform
# ------------------------------------------------------------
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
terraform.tfvars
*.auto.tfvars
!*.auto.tfvars.example

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
*~

# ------------------------------------------------------------
# Editors
# ------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# Assets — vidéos (trop lourdes pour git, utiliser Git LFS si nécessaire)
# ------------------------------------------------------------
assets/screenshots/*.mp4
assets/screenshots/*.webm

# ------------------------------------------------------------
# Logs & Temp
# ------------------------------------------------------------
*.log
tmp/
temp/

# ------------------------------------------------------------
# Image Testing (ADR-700 / ADR-701)
# ------------------------------------------------------------
.image-test-state
image-tests/env/.env.test
playwright-report/
test-results/
.test-reports/
node_modules/
