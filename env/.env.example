# ============================================================
# nextcloud-marketplace — Environment Variables
# Copy to env/.env and fill in values
# NEVER commit env/.env to version control
# ============================================================

# ------------------------------------------------------------
# Azure Authentication
# Use environment variables or a service principal
# For GitHub Actions: set these as repository secrets
# ------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=

# ------------------------------------------------------------
# Azure Resources — Packer build environment
# ------------------------------------------------------------
AZURE_LOCATION=canadacentral
BUILD_RESOURCE_GROUP=rg-nextcloud-packer-build

# ------------------------------------------------------------
# Azure Compute Gallery — Image destination
# ------------------------------------------------------------
GALLERY_RESOURCE_GROUP=rg-nextcloud-gallery
GALLERY_NAME=gal_nextcloud_marketplace
GALLERY_IMAGE_NAME=nextcloud-marketplace
REPLICATION_REGIONS=canadacentral eastus

# ------------------------------------------------------------
# Build configuration
# ------------------------------------------------------------
IMAGE_VERSION=0.1.0
ENVIRONMENT=dev
VM_SIZE=Standard_D4s_v3

# ------------------------------------------------------------
# Nextcloud
# ------------------------------------------------------------
NC_VERSION=31.0.2
NC_ADMIN_USER=ncadmin
