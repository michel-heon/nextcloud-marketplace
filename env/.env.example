# ============================================================
# nextcloud-marketplace — Variables publiques de configuration
# Copier vers env/.env et remplir les valeurs
# JAMAIS commiter env/.env dans Git
#
# Pour les credentials Azure (CLIENT_ID / CLIENT_SECRET),
# voir env/.env.user.example → copier vers env/.env.user
# ============================================================

# ------------------------------------------------------------
# Azure Identity (identifiants non-secrets — subscription / tenant)
# ------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# ------------------------------------------------------------
# Azure Resources — Packer build environment
# ------------------------------------------------------------
AZURE_LOCATION=canadacentral
BUILD_RESOURCE_GROUP=rg-nextcloud-marketplace-build

# ------------------------------------------------------------
# Azure Compute Gallery — Image destination
# ------------------------------------------------------------
GALLERY_RESOURCE_GROUP=rg-nextcloud-marketplace
GALLERY_NAME=gal_nextcloud_marketplace
GALLERY_IMAGE_NAME=nextcloud-marketplace
REPLICATION_REGIONS=canadacentral eastus

# ------------------------------------------------------------
# Build configuration
# ------------------------------------------------------------
IMAGE_VERSION=0.2.0
ENVIRONMENT=dev
VM_SIZE=Standard_D4s_v3

# ------------------------------------------------------------
# Nextcloud
# ------------------------------------------------------------
NC_VERSION=31.0.2
NC_ADMIN_USER=ncadmin

# ------------------------------------------------------------
# Blob Storage Cache (ADR-616)
# Laisser vide pour désactiver le cache (fallback source directe)
# ------------------------------------------------------------
BLOB_STORAGE_ACCOUNT_NAME=stncmarketplace
BLOB_STORAGE_CONTAINER=devops
BLOB_STORAGE_BASE_URL=https://stncmarketplace.blob.core.windows.net/devops
